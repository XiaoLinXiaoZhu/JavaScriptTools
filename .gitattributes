# 统一行尾为 LF，避免 Windows CRLF 警告
* text=auto eol=lf

# 确保以下文件类型始终使用 LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json   text eol=lf
*.css   text eol=lf
*.vue   text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.svg   text eol=lf
*.txt   text eol=lf

# 二进制文件
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
