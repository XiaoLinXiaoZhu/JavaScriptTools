{
  "name": "javascript-tools",
  "version": "1.0.0",
  "description": "油猴脚本集合 - TypeScript monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:watch": "bun run scripts/build.ts --watch",
    "manifest": "bun run scripts/manifest.ts",
    "typecheck": "tsc --noEmit",
    "clean": "bun run clean.mjs",
    "demo": "bun run packages/styles/demo/build.ts && start packages/styles/demo/index.html",
    "preview": "cd apps/preview && bun run dev"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "chokidar": "^4.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "dependencies": {
    "number-flow": "^0.6.0"
  }
}
